import {
  activate,
  call,
  init,
  kinds,
  normalize_inbound,
  payload_schema,
  provider_id,
  shutdown,
} from "../src/lib"

@complexity(allow)
pipeline test_sourcehut_connector(task) {
  egress_policy({allow: ["git.sr.ht", "todo.sr.ht", "builds.sr.ht"], default: "deny"})
  shutdown()
  assert_eq(provider_id(), "sourcehut", "provider id")
  assert_eq(kinds()[0], "webhook", "first kind")
  assert_eq(payload_schema().harn_schema_name, "SourceHutEventPayload", "schema")
  let keypair = ed25519_keypair()
  // Seed the public key via init(ctx) — never via inbound `raw.public_key`.
  init({public_key: keypair.public})
  let activated = activate([{id: "primary", path: "/hooks/sourcehut", secrets: {public_key: keypair.public}}])
  assert_eq(activated.bindings, 1, "activation count")
  let body = "{\"event\":\"repo.push\",\"repository\":{\"name\":\"~ada/widgets\",\"url\":\"https://git.sr.ht/~ada/widgets\"},\"pusher\":{\"canonical_name\":\"~ada\"},\"commits\":[{\"id\":\"abc123\"}]}"
  let headers = {"x-sourcehut-event": "repo.push", "x-sourcehut-delivery": "delivery-1"}
  let signature = ed25519_sign(keypair.private, body)
  let raw = {
    binding_id: "primary",
    body_text: body,
    headers: headers + {"x-sourcehut-signature": "ed25519=" + signature},
  }
  let normalized = normalize_inbound(raw)
  assert_eq(normalized.type, "event", "envelope type")
  assert_eq(normalized.event.kind, "repo.push", "event kind")
  assert_eq(normalized.event.signature_status.state, "verified", "signed status")
  assert(normalized.event.dedupe_key != nil && normalized.event.dedupe_key != "", "dedupe key")
  let bad_signature = normalize_inbound(
    {binding_id: "primary", body_text: body, headers: headers + {"x-sourcehut-signature": "ed25519=00"}},
  )
  assert_eq(bad_signature.type, "reject", "bad signature rejects")
  assert_eq(bad_signature.reject.status, 401, "bad signature status")
  let wrong_signature_scheme = normalize_inbound(
    {
      binding_id: "primary",
      body_text: body,
      headers: headers + {"x-sourcehut-signature": "sha256=" + signature},
    },
  )
  assert_eq(wrong_signature_scheme.type, "reject", "wrong signature scheme rejects")
  assert_eq(wrong_signature_scheme.reject.status, 401, "wrong signature scheme status")
  let missing_signature = normalize_inbound({binding_id: "primary", body_text: body, headers: headers})
  assert_eq(
    missing_signature.type,
    "reject",
    "missing signature rejects when a public key is configured",
  )
  assert_eq(missing_signature.reject.status, 401, "missing signature status")
  // F8: missing binding_id is fail-closed.
  let no_binding = normalize_inbound(
    {body_text: body, headers: headers + {"x-sourcehut-signature": "ed25519=" + signature}},
  )
  assert_eq(no_binding.type, "reject", "missing binding_id rejects")
  assert_eq(no_binding.reject.status, 400, "missing binding_id status")
  let alternate_signature_header = normalize_inbound(
    {binding_id: "primary", body_text: body, headers: headers + {"x-srht-signature": signature}},
  )
  assert_eq(alternate_signature_header.type, "event", "alternate signature header verifies")
  assert_eq(
    alternate_signature_header.event.signature_status.state,
    "verified",
    "alternate signed status",
  )
  assert_eq(
    alternate_signature_header.event.headers["x-srht-signature"],
    signature,
    "alternate signature header is preserved",
  )
  let enum_body = "{\"webhook\":{\"uuid\":\"delivery-2\",\"event\":\"GIT_POST_RECEIVE\"},\"repository\":{\"rid\":\"repo-1\",\"name\":\"widgets\",\"repoPath\":\"~ada/widgets\"}}"
  let sourcehut_enum_event = normalize_inbound(
    {
      binding_id: "primary",
      body_text: enum_body,
      headers: {"x-sourcehut-signature": ed25519_sign(keypair.private, enum_body)},
    },
  )
  assert_eq(sourcehut_enum_event.type, "event", "SourceHut enum event verifies")
  assert_eq(sourcehut_enum_event.event.kind, "git.post_receive", "SourceHut enum event maps")
  assert_eq(sourcehut_enum_event.event.payload.provider, "sourcehut", "payload carries provider")
  assert_eq(
    sourcehut_enum_event.event.payload.delivery_id,
    "delivery-2",
    "payload carries delivery id",
  )
  let ticket_body = "{\"webhook\":{\"uuid\":\"ticket-1\",\"event\":\"TICKET_CREATED\",\"date\":\"2026-05-22T09:30:00Z\",\"ticket\":{\"id\":42,\"ref\":\"todo.sr.ht/~ada/widgets/42\",\"subject\":\"Fix widgets\"}},\"submitter\":{\"canonical_name\":\"~ada\"}}"
  let sourcehut_ticket_event = normalize_inbound(
    {
      binding_id: "primary",
      body_text: ticket_body,
      headers: {"x-sourcehut-signature": ed25519_sign(keypair.private, ticket_body)},
    },
  )
  assert_eq(sourcehut_ticket_event.type, "event", "SourceHut ticket event verifies")
  assert_eq(sourcehut_ticket_event.event.kind, "ticket.created", "SourceHut ticket enum maps")
  assert_eq(
    sourcehut_ticket_event.event.occurred_at,
    "2026-05-22T09:30:00Z",
    "SourceHut webhook date maps to occurred_at",
  )
  assert_eq(sourcehut_ticket_event.event.payload.resource.id, 42, "ticket resource is preserved")
  let build_body = "{\"webhook\":{\"uuid\":\"job-1\",\"event\":\"JOB_UPDATED\",\"date\":\"2026-05-22T09:31:00Z\"},\"job\":{\"id\":7,\"status\":\"SUCCESS\"}}"
  let sourcehut_build_event = normalize_inbound(
    {
      binding_id: "primary",
      body_text: build_body,
      headers: {"x-sourcehut-signature": ed25519_sign(keypair.private, build_body)},
    },
  )
  assert_eq(sourcehut_build_event.type, "event", "SourceHut build event verifies")
  assert_eq(sourcehut_build_event.event.kind, "build.updated", "SourceHut build enum maps")
  assert_eq(
    sourcehut_build_event.event.payload.resource.status,
    "SUCCESS",
    "job resource is preserved",
  )
  assert_eq(
    sourcehut_build_event.event.payload.build.status,
    "SUCCESS",
    "build summary lifts job status",
  )
  assert_eq(sourcehut_build_event.event.payload.build.succeeded, true, "build summary marks success")
  assert_eq(sourcehut_build_event.event.payload.build.failed, false, "successful build is not failed")
  // JOB_UPDATED with a failed status surfaces payload.build.failed clearly.
  let failed_build_body = "{\"webhook\":{\"uuid\":\"job-2\",\"event\":\"JOB_UPDATED\",\"date\":\"2026-05-22T09:32:00Z\"},\"job\":{\"id\":8,\"status\":\"FAILED\"}}"
  let sourcehut_failed_build = normalize_inbound(
    {
      binding_id: "primary",
      body_text: failed_build_body,
      headers: {"x-sourcehut-signature": ed25519_sign(keypair.private, failed_build_body)},
    },
  )
  assert_eq(sourcehut_failed_build.type, "event", "failed build event verifies")
  assert_eq(sourcehut_failed_build.event.kind, "build.updated", "failed build enum maps")
  assert_eq(sourcehut_failed_build.event.payload.build.status, "FAILED", "failed build status lifted")
  assert_eq(sourcehut_failed_build.event.payload.build.failed, true, "failed build flagged")
  assert_eq(sourcehut_failed_build.event.payload.build.succeeded, false, "failed build not succeeded")
  let invalid_json = normalize_inbound(
    {
      binding_id: "primary",
      body_text: "{bad json",
      headers: headers + {"x-sourcehut-signature": "ed25519=" + ed25519_sign(keypair.private, "{bad json")},
    },
  )
  assert_eq(invalid_json.type, "reject", "invalid json rejects")
  let unsupported_prefix = normalize_inbound(
    {
      binding_id: "primary",
      body_text: "{\"event\":\"repo.push_extra\"}",
      headers: {
        "x-sourcehut-signature": "ed25519="
          + ed25519_sign(keypair.private, "{\"event\":\"repo.push_extra\"}"),
      },
    },
  )
  assert_eq(unsupported_prefix.type, "reject", "unsupported prefix event rejects")
  assert_eq(unsupported_prefix.reject.status, 400, "unsupported prefix status")
  // F1: absolute-URL path in api.request is rejected (SSRF guard).
  let ssrf = call(
    "api.request",
    {
      api_base_url: "https://git.sr.ht/query",
      path: "https://attacker.example.com/steal",
      api_token: "token",
      rate_limit: false,
    },
  )
  assert(is_err(ssrf), "absolute URL path rejected")
  http_mock_clear()
  http_mock(
    "GET",
    "https://git.sr.ht/query/projects",
    {status: 200, body: json_stringify({ok: true})},
  )
  let response = call(
    "api.request",
    {api_base_url: "https://git.sr.ht/query", path: "/projects", api_token: "token", rate_limit: false},
  )
  assert_eq(response.ok, true, "api request")
  let api_calls = http_mock_calls({redact_sensitive: false})
  assert(contains(json_stringify(api_calls[0]), "Bearer token"), "api_token authorizes request")
  http_mock_clear()
  shutdown()
  init()
  http_mock(
    "GET",
    "https://git.sr.ht/query/projects",
    {
      status: 200,
      headers: {"x-ratelimit-limit": "10", "x-ratelimit-remaining": "9", "x-ratelimit-reset": "1776859300"},
      body: json_stringify({ok: true}),
    },
  )
  let metered = call(
    "api.request",
    {
      api_base_url: "https://git.sr.ht/query",
      path: "/projects",
      access_token: "token",
      include_meta: true,
      rate_limit: {capacity: 1, refill_tokens: 1, refill_interval_ms: 1000},
      now_ms: 1000,
    },
  )
  assert_eq(metered.meta.rate_limit.requests_remaining, 9, "rate-limit response metadata")
  let bucket_limited = call(
    "api.request",
    {
      api_base_url: "https://git.sr.ht/query",
      path: "/projects",
      access_token: "token",
      rate_limit: {capacity: 1, refill_tokens: 1, refill_interval_ms: 1000},
      now_ms: 1000,
    },
  )
  assert(is_err(bucket_limited), "token bucket blocks exhausted scope")
  assert_eq(unwrap_err(bucket_limited).code, "rate_limited", "token bucket error code")
  assert_eq(unwrap_err(bucket_limited).retry_after_ms, 1000, "token bucket retry after")
  http_mock_clear()
  http_mock(
    "GET",
    "https://git.sr.ht/query/projects",
    {
      status: 429,
      headers: {"retry-after": "2", "x-ratelimit-remaining": "0"},
      body: json_stringify({message: "slow down"}),
    },
  )
  let header_limited = call(
    "api.request",
    {
      api_base_url: "https://git.sr.ht/query",
      path: "/projects",
      access_token: "token",
      rate_limit: false,
    },
  )
  assert(is_err(header_limited), "429 rate limit rejects")
  assert_eq(unwrap_err(header_limited).code, "rate_limited", "429 error code")
  assert_eq(unwrap_err(header_limited).meta.rate_limit.retry_after_ms, 2000, "429 retry after")
  http_mock_clear()
  http_mock(
    "GET",
    "https://git.sr.ht/query/projects",
    {
      status: 403,
      headers: {"x-ratelimit-remaining": "0", "x-ratelimit-reset": "1776859300"},
      body: json_stringify({message: "primary rate limit"}),
    },
  )
  let exhausted = call(
    "api.request",
    {
      api_base_url: "https://git.sr.ht/query",
      path: "/projects",
      access_token: "token",
      rate_limit: false,
    },
  )
  assert(is_err(exhausted), "403 with exhausted rate-limit headers rejects")
  assert_eq(unwrap_err(exhausted).code, "rate_limited", "403 exhausted rate-limit code")
  http_mock_clear()
  http_mock(
    "POST",
    "https://git.sr.ht/query",
    {
      responses: [
        {
          status: 200,
          body: json_stringify({data: {repositories: {results: [{name: "alpha"}], cursor: "page-2"}}}),
        },
        {
          status: 200,
          body: json_stringify({data: {repositories: {results: [{name: "beta"}], cursor: nil}}}),
        },
      ],
    },
  )
  let paged = call(
    "graphql.paginate",
    {
      api_base_url: "https://git.sr.ht/query",
      access_token: "token",
      query: "query Repositories($cursor: Cursor) { repositories(cursor: $cursor) { results { name } cursor } }",
      page_path: "/repositories",
      rate_limit: false,
    },
  )
  assert_eq(len(paged.items), 2, "cursor pagination item count")
  assert_eq(paged.items[0].name, "alpha", "first paginated item")
  assert_eq(paged.items[1].name, "beta", "second paginated item")
  assert_eq(paged.complete, true, "cursor pagination complete")
  let calls = http_mock_calls({include_sensitive: true})
  assert(contains(json_stringify(calls[0]), "content-type"), "graphql request sets content type")
  assert(contains(calls[1].body, "\"cursor\":\"page-2\""), "second page uses cursor")
  // Typed convenience helpers target the service-specific GraphQL endpoint.
  http_mock_clear()
  http_mock(
    "POST",
    "https://todo.sr.ht/query",
    {
      status: 200,
      body: json_stringify({data: {submitComment: {id: 99, created: "2026-05-22T10:00:00Z"}}}),
    },
  )
  let commented = call(
    "ticket.comment",
    {
      access_token: "token",
      resolution: "fixed",
      status: "resolved",
      text: "thanks, fixed in r123",
      ticket_id: 42,
      tracker_id: 7,
    },
  )
  assert_eq(commented.data.submitComment.id, 99, "ticket.comment returns submitComment event")
  let comment_calls = http_mock_calls({include_sensitive: true})
  assert(
    contains(comment_calls[0].body, "submitComment"),
    "ticket.comment uses submitComment mutation",
  )
  assert(
    contains(comment_calls[0].body, "\"status\":\"RESOLVED\""),
    "ticket.comment upcases status enum",
  )
  let missing_text = call("ticket.comment", {access_token: "token", ticket_id: 42, tracker_id: 7})
  assert(is_err(missing_text), "ticket.comment requires text")
  assert_eq(unwrap_err(missing_text).code, "invalid_args", "ticket.comment missing text code")
  http_mock_clear()
  http_mock(
    "POST",
    "https://todo.sr.ht/query",
    {
      status: 200,
      body: json_stringify({data: {updateTicketStatus: {id: 100, created: "2026-05-22T10:01:00Z"}}}),
    },
  )
  let status_updated = call(
    "ticket.update_status",
    {access_token: "token", resolution: "fixed", status: "resolved", ticket_id: 42, tracker_id: 7},
  )
  assert_eq(
    status_updated.data.updateTicketStatus.id,
    100,
    "ticket.update_status returns updateTicketStatus event",
  )
  let status_calls = http_mock_calls({include_sensitive: true})
  assert(
    contains(status_calls[0].body, "updateTicketStatus"),
    "ticket.update_status uses updateTicketStatus mutation",
  )
  let missing_status = call("ticket.update_status", {access_token: "token", ticket_id: 42, tracker_id: 7})
  assert(is_err(missing_status), "ticket.update_status requires status")
  http_mock_clear()
  http_mock(
    "POST",
    "https://builds.sr.ht/query",
    {status: 200, body: json_stringify({data: {job: {id: 8, note: nil, status: "FAILED"}}})},
  )
  let build_status = call("build.get", {access_token: "token", job_id: 8})
  assert_eq(build_status.data.job.status, "FAILED", "build.get reads job status")
  let build_get_calls = http_mock_calls({include_sensitive: true})
  assert(contains(build_get_calls[0].body, "job(id:"), "build.get queries job by id")
  let missing_job = call("build.get", {access_token: "token"})
  assert(is_err(missing_job), "build.get requires job_id")
  http_mock_clear()
  http_mock(
    "POST",
    "https://builds.sr.ht/query",
    {status: 200, body: json_stringify({data: {submit: {id: 9, note: nil, status: "PENDING"}}})},
  )
  let submitted = call(
    "build.submit",
    {access_token: "token", manifest: "image: alpine/edge\ntasks: []\n", note: "ci"},
  )
  assert_eq(submitted.data.submit.status, "PENDING", "build.submit returns created job status")
  let submit_calls = http_mock_calls({include_sensitive: true})
  assert(contains(submit_calls[0].body, "submit("), "build.submit uses submit mutation")
  let missing_manifest = call("build.submit", {access_token: "token"})
  assert(is_err(missing_manifest), "build.submit requires manifest")
  http_mock_clear()
  let unsupported_source_control_helper = call("repository_file.get", {})
  assert(is_err(unsupported_source_control_helper), "provider-specific unsupported helper errors")
  assert_eq(
    unwrap_err(unsupported_source_control_helper).code,
    "method_not_found",
    "unsupported helper error code",
  )
  let unsupported = call("unknown", {})
  assert(is_err(unsupported), "unknown method errors")
  http_mock_clear()
  shutdown()
}
